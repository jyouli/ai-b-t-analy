VITE_MODE=development
VITE_API_BASE=/universe
# 业务 /universe（含 /universe/paas/...）→ 测试环境业务域（生产构建后走当前站点同源，无需此项）
VITE_PROXY_TARGET=https://dev3.cloud.hecom.cn
# VITE_PROXY_TARGET=https://dev2.cloud.hecom.cn
# 开发走同源 + Vite 代理，避免 localhost 直连 tc 域名触发 CORS / Referer 限制
VITE_TC_URL=/hecom-tenancy/
VITE_TC_PROXY_TARGET=https://tc-dev.cloud.hecom.cn
# VITE_IM_HOST=  VITE_RCM_HOST=  VITE_EXPRESSION_HOST=  可选，默认同 foreground 生产